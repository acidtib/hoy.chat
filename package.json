{
  "name": "hoy.chat",
  "private": true,
  "version": "0.1.3",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter 'hoy-desktop' dev",
    "build": "bun run --filter 'hoy-desktop' build",
    "preview": "bun run --filter 'hoy-desktop' preview",
    "tauri": "bun run --filter 'hoy-desktop' tauri",
    "tauri:dev": "bun run --filter 'hoy-desktop' tauri:dev",
    "sidecar:build": "bun run --filter '@hoy/sidecar' build",
    "site:dev": "bun run --filter '@hoy/site' dev",
    "site:build": "bun run --filter '@hoy/site' build",
    "site:start": "bun run --filter '@hoy/site' start",
    "site:lint": "bun run --filter '@hoy/site' lint",
    "local:install": "bash scripts/local-install.sh",
    "test": "bun run --filter 'hoy-desktop' test",
    "check": "bun run --filter 'hoy-desktop' check && bun run --filter '@hoy/sidecar' check:ts",
    "check:ts": "bun run --filter 'hoy-desktop' check:ts",
    "check:sidecar": "bun run --filter '@hoy/sidecar' check:ts",
    "check:rust": "bun run --filter 'hoy-desktop' check:rust",
    "clippy": "bun run --filter 'hoy-desktop' clippy",
    "check:fmt": "bun run --filter 'hoy-desktop' check:fmt",
    "lint": "bun run --filter 'hoy-desktop' lint",
    "lint:js": "bun run --filter 'hoy-desktop' lint:js",
    "lint:rust": "bun run --filter 'hoy-desktop' lint:rust"
  }
}

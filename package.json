{
  "name": "hoy.chat",
  "private": true,
  "version": "0.1.1",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "cd apps/desktop && bun run dev",
    "build": "cd apps/desktop && bun run build",
    "preview": "cd apps/desktop && bun run preview",
    "tauri": "cd apps/desktop && bun run tauri",
    "tauri:dev": "cd apps/desktop && bun run tauri:dev",
    "local:install": "bash scripts/local-install.sh",
    "test": "cd apps/desktop && bun test",
    "check": "cd apps/desktop && bun run check && cd ../../packages/sidecar/pi-src && bun run check:ts",
    "check:ts": "cd apps/desktop && bun run check:ts",
    "check:sidecar": "cd packages/sidecar/pi-src && bun run check:ts",
    "check:rust": "cd apps/desktop && bun run check:rust",
    "clippy": "cd apps/desktop && bun run clippy",
    "check:fmt": "cd apps/desktop && bun run check:fmt",
    "lint": "cd apps/desktop && bun run lint",
    "lint:js": "cd apps/desktop && bun run lint:js",
    "lint:rust": "cd apps/desktop && bun run lint:rust"
  }
}

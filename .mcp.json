{
  "mcpServers": {
    "shadcn": {
      "command": "bunx",
      "args": ["shadcn@latest", "mcp"]
    },
    "playwright": {
      "command": "bunx",
      "args": ["@playwright/mcp@latest", "--browser", "firefox"]
    },
    "tauri": {
      "command": "bunx",
      "args": ["@hypothesi/tauri-mcp-server"]
    }
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": "..",
    "paths": { "@/*": ["./src/*"] },
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "../dist/types",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false
  },
  "include": [
    "../src/components/ui/**/*.tsx",
    "../src/components/ai-elements/**/*.tsx"
  ]
}

# Maintainer: acidtib <arubinofaux@gmail.com>

# Binary package for Arch: repackages the official Debian release asset (which
# already ships a clean FHS layout) into a pacman package. No build from source,
# so it installs fast and matches the exact bytes we release.

pkgname=hoy-desktop-bin
_appname=hoy-desktop
pkgver=0.1.1
pkgrel=1
pkgdesc="A native desktop app for coding agents (Hoy Chat), powered by the Pi agent"
arch=('x86_64')
url="https://hoy.chat"
license=('MIT')
# Maps the .deb's declared runtime deps (libwebkit2gtk-4.1-0, libgtk-3-0) to Arch.
depends=('webkit2gtk-4.1' 'gtk3')
provides=("${_appname}")
conflicts=("${_appname}")
# The 'pi' sidecar is a bun single-file executable; do not strip it.
options=('!strip')
source=("${_appname}-${pkgver}.deb::https://github.com/acidtib/hoy.chat/releases/download/v${pkgver}/Hoy.Desktop_${pkgver}_amd64.deb")
noextract=("${_appname}-${pkgver}.deb")
sha256sums=('44c8f595c1ce19112edd39b085ec2c372dffbd635d6dee95ccc3aacf1e6379d0')

package() {
  # Pull whatever data.tar.* the .deb carries (gz/xz/zst) and unpack it, with the
  # release's FHS layout intact: /usr/bin/hoy-desktop, the /usr/bin/pi sidecar,
  # resources under "/usr/lib/Hoy Desktop", the .desktop entry, and hicolor icons.
  bsdtar -xOf "${_appname}-${pkgver}.deb" 'data.tar*' | bsdtar -xpf - -C "${pkgdir}"
}

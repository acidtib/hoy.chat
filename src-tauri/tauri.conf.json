{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hoy Desktop",
  "version": "0.1.0",
  "identifier": "dev.hoy-desktop.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Hoy Desktop",
        "width": 1536,
        "height": 960,
        "minWidth": 880,
        "minHeight": 560,
        "decorations": false,
        "backgroundColor": "#0e0e10"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["../sidecar/pi"],
    "resources": {
      "../sidecar/pi-payload": "pi-payload"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
